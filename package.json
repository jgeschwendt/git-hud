{
	"name": "git-hud",
	"version": "0.1.1",
	"description": "Git worktree dashboard with bare repository management",
	"type": "module",
	"scripts": {
		"build": "bun --bun next build && bash scripts/build.sh",
		"check": "biome check .",
		"dev": "bun --bun next dev",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"start": "bun run cli/index.tsx"
	},
	"dependencies": {
		"ink": "^6.6.0",
		"minimatch": "^10.1.1",
		"next": "^16.1.1",
		"react": "^19.2.3",
		"react-dom": "^19.2.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"@types/bun": "^1.3.5",
		"@types/node": "^25.0.3",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"react-devtools-core": "^7.0.1",
		"typescript": "^5.9.3"
	}
}
